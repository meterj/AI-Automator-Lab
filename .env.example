# Public site / WordPress settings
WORDPRESS_SITE_URL=https://ai-automator-lab.vercel.app
WORDPRESS_USERNAME=your_username
WORDPRESS_PASSWORD=your_application_password
WORDPRESS_API_URL=https://public-api.wordpress.com/rest/v1.1/sites/YOUR_SITE_ID/posts

# Groq AI settings
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-8b-8192

# RSS feed settings
RSS_FEEDS=https://techcrunch.com/category/artificial-intelligence/feed/,https://venturebeat.com/category/ai/feed/,https://openai.com/news/rss.xml,https://www.artificialintelligence-news.com/feed/

# Scheduler settings
SCHEDULE_CRON=0 9 * * *
SCHEDULE_ENABLED=true
SCHEDULE_MODE=rss
SCHEDULE_TRIGGER_TOKEN=replace_with_a_long_random_token

# Server settings
PORT=3000
NODE_ENV=development

# Database / Supabase settings
DATABASE_PATH=./data/posts.db
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
