# WordPress.com 설정
WORDPRESS_SITE_URL=https://yourblog.wordpress.com
WORDPRESS_USERNAME=your_username
WORDPRESS_PASSWORD=your_application_password
WORDPRESS_API_URL=https://public-api.wordpress.com/rest/v1.1/sites/YOUR_SITE_ID/posts

# OpenAI 설정
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# RSS 설정 (선택사항)
RSS_FEEDS=https://example.com/feed,https://another-site.com/rss

# 스케줄러 설정
SCHEDULE_CRON=0 9 * * *

# 서버 설정
PORT=3000
NODE_ENV=development

# 데이터베이스
DATABASE_PATH=./data/posts.db