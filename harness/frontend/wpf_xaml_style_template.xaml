<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 색상 토큰 -->
    <SolidColorBrush x:Key="Color.Primary" Color="#00E5FF"/>
    <SolidColorBrush x:Key="Color.TextPrimary" Color="#DFFEFF"/>
    <SolidColorBrush x:Key="Color.PanelBackground" Color="#0A1F28"/>

    <!-- 텍스트 스타일 -->
    <Style x:Key="BaseTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Color.TextPrimary}"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>

    <!-- 버튼 스타일 -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource Color.Primary}"/>
        <Setter Property="Padding" Value="12,6"/>
    </Style>
</ResourceDictionary>
